    {
      "id": "mapo-tofu",
      "name_cn": "麻婆豆腐",
      "name_en": "Mapo Tofu",
      "aliases": [
        "麻婆豆腐",
        "mapo doufu",
        "spicy tofu",
        "麻辣豆腐"
      ],
      "image": "",
      "image_credit": "none",
      "tags": [
        "川菜",
        "豆腐",
        "辣",
        "家常菜",
        "下饭菜"
      ],
      "steps": [
        "嫩豆腐切约2cm方块，入沸水中加少许盐汆烫1分钟后捞出备用。",
        "锅中下油，中火炒香猪肉末至变色。",
        "加入郫县豆瓣酱炒出红油，再加姜末、蒜末翻炒出香味。",
        "倒入约200ml清水（或高汤），放入豆腐块，轻推不翻炒，小火煮3分钟。",
        "加生抽、少许盐调味，勾水淀粉芡至汤汁浓稠。",
        "出锅前淋几滴芝麻油，撒上花椒粉，即可盛盘。"
      ],
      "ingredients": [
