    {
      "id": "beef-chow-fun",
      "name_cn": "干炒牛河",
      "name_en": "Dry-Fried Beef Ho Fun",
      "aliases": [
        "炒牛河",
        "干炒河粉",
        "ganChao niuhe",
        "beef ho fun",
        "干炒牛肉河粉"
      ],
      "section": "fresh",
      "kind": "dish",
      "fresh": true,
      "priority": 99,
      "image": "",
      "image_credit": "none",
      "tags": [
        "粤菜",
        "河粉",
        "牛肉",
        "本周鲜货",
        "经典",
        "快手菜"
      ],
      "steps": [
        "牛肉卷解冻后切薄片，加生抽、老抽、蚝油、少许淀粉抓匀腌制15分钟。",
        "河粉用温水浸泡约5分钟后轻轻分开，沥干备用；豆芽摘去根须洗净；小葱切段。",
        "锅中大火烧至冒烟，下油至滑锅，下牛肉片大火快炒至变色（约1分钟），盛出备用。",
        "原锅大火，再下少许油，下河粉大火翻炒（动作快，避免粘连）。",
        "加老抽翻炒上色，下豆芽和葱段快速翻炒约30秒。",
