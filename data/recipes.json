    {
      "id": "red-braised-pork",
      "name_cn": "红烧肉",
      "name_en": "Red-Braised Pork Belly",
      "aliases": [
        "红烧五花肉",
        "东坡肉",
        "hong shao rou",
        "braised pork belly"
      ],
      "section": "tonight",
      "kind": "dish",
      "priority": 95,
      "image": "",
      "image_credit": "none",
      "tags": [
        "猪肉",
        "红烧",
        "下饭菜",
        "家常菜",
        "经典"
      ],
      "steps": [
        "五花肉切成约4cm正方块，冷水下锅，加料酒，大火焯水5分钟去腥，捞出洗净沥干。",
        "锅中下少许油，中火将肉块各面煎至微金黄，逼出多余油脂，盛出备用。",
        "锅中留底油，下冰糖中小火慢慢炒化，至变成棕红色焦糖（勿焦苦）。",
        "迅速将五花肉倒入，翻炒使肉块均匀裹上焦糖色。",
        "加生抽、老抽翻炒上色，倒入热水至八分没过肉块，下姜片。",
        "大火烧开后转小火加盖焖煮45-60分钟至肉质软烂。",
        "转大火收汁至浓稠发亮，出锅撒葱花即可。"
      ],
      "ingredients": [
        {
          "label": "五花肉（带皮）",
