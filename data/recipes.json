    {
      "id": "braised-beef-brisket",
      "name_cn": "红烧牛腩",
      "name_en": "Red-Braised Beef Brisket",
      "aliases": [
        "红烧牛肉",
        "hong shao niunan",
        "braised brisket"
      ],
