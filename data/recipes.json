    {
      "id": "blanched-choy-sum",
      "name_cn": "白灼菜心",
      "name_en": "Blanched Choy Sum with Soy Sauce",
      "aliases": [
        "白灼菜心",
        "油菜心",
        "you choy sum",
        "清烫菜心"
      ],
      "image": "",
      "image_credit": "none",
      "tags": [
        "粤菜",
        "素菜",
        "快手菜",
        "蔬菜",
        "健康"
      ],
      "steps": [
        "菜心择洗干净，较粗茎部可竖切一刀，使受热均匀。",
        "锅中烧开足量水，加少许盐和几滴油，下菜心汆烫1-2分钟至碧绿断生，捞出摆盘。",
        "调酱汁：小碗中混合生抽、少许蚝油、糖，搅匀。",
        "在菜心上铺少许葱丝或姜丝。",
        "锅中烧少许油至冒烟，迅速淋在葱姜丝上激出香气，再淋上酱汁，即可上桌。"
      ],
