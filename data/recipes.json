    {
      "id": "cola-chicken-wings",
      "name_cn": "可乐鸡翅",
      "name_en": "Cola Braised Chicken Wings",
      "aliases": [
        "可乐鸡翅",
        "cola chicken wings",
        "braised chicken wings",
        "焖鸡翅"
      ],
      "image": "",
      "image_credit": "none",
      "tags": [
        "家常菜",
        "鸡肉",
        "下饭菜",
        "儿童喜爱",
        "红烧"
      ],
      "steps": [
        "鸡全翅洗净，在翅面划两刀以便入味。",
        "冷水入锅，加料酒，大火焯出血沫（约3分钟），捞出洗净沥干。",
        "锅热少许油，中火煎鸡翅两面至金黄（约3分钟/面）。",
        "加姜片、生抽、老抽翻炒，使鸡翅均匀上色。",
        "倒入可乐（约355ml，正好一罐），没过鸡翅约一半。",
        "大火烧开转中小火焖煮15-18分钟，期间翻面1-2次。",
        "转大火收汁至浓稠发亮，出锅撒葱花。"
      ],
      "ingredients": [
