    {
      "id": "tomato-egg",
      "name_cn": "番茄炒蛋",
      "name_en": "Stir-Fried Tomato and Egg",
      "aliases": [
        "番茄炒鸡蛋",
        "西红柿炒蛋",
        "tomato egg stir fry",
        "炒鸡蛋"
      ],
      "image": "",
      "image_credit": "none",
      "tags": [
        "家常菜",
        "快手菜",
        "下饭菜",
        "素菜"
      ],
      "steps": [
        "鸡蛋打散，加少许盐搅匀。番茄切块备用。",
        "锅热油（大火），倒入蛋液炒至半凝固后划散成块，盛出备用。",
        "锅中再加少许油，下番茄块大火翻炒，炒至出汁软烂（约2分钟）。",
        "加盐和少许糖调味，可加少许番茄酱提色增味。",
        "倒回炒好的鸡蛋，翻炒均匀，撒葱花，出锅。"
