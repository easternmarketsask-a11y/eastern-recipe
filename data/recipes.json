{
  "recipes": [
    {
      "id": "hotpot",
      "name_cn": "在家涮火锅",
      "name_en": "Home-Style Hot Pot",
      "aliases": [
        "火锅",
        "涮火锅",
        "hotpot",
        "huoguo"
      ],
      "section": "tonight",
      "kind": "dish",
      "priority": 100,
      "image": "",
      "image_credit": "none",
      "tags": [
        "火锅",
        "羊肉",
        "牛肉",
        "聚会",
        "家庭聚餐",
        "下饭"
      ],
      "steps": [
        "将牛油火锅底料放入锅中，加约1.5升清水，大火煮沸后转中火，底料完全融化即为锅底。",
        "龙口粉丝提前用冷水泡发约20分钟；金针菇去根、大白菜切段、鱼豆腐和传统豆腐切厚片备用。",
        "新西兰羔羊卷和牛肉卷从冰箱取出，室温回温约10分钟，方便涮食时均匀受热。",
        "锅底沸腾后先下豆腐类食材（鱼豆腐、传统豆腐）煮2-3分钟，再依次下大白菜、金针菇、粉丝。",
        "羊肉卷和牛肉卷薄片入锅涮15-30秒至变色即捞出，蘸酱食用（麻酱/沙茶酱均可）。",
        "撒入小葱葱花提香，边涮边加料即可享用。"
      ],
      "ingredients": [
        {
