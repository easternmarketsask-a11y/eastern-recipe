    {
      "id": "white-cut-chicken",
      "name_cn": "白切鸡",
      "name_en": "White-Cut Chicken",
      "aliases": [
        "白斩鸡",
        "清水鸡",
        "bai qie ji",
        "poached chicken"
      ],
      "section": "tonight",
